# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Bcrypt
# ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
